generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Prospect {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name  String
  phone String @unique
  email String?
  age   Int?

  qualifObjectif   String?
  qualifDelai      String?
  qualifFrein      String?
  qualifExperience String?
  qualifDisponible String?
  qualifSante      String?
  qualifMotivation String?
  qualifBudget     String?

  weight        Float?
  height        Float?
  availableDays String?
  nutritionInfo String?
  photosReceived Boolean @default(false)
  onboardingDone Boolean @default(false)

  status String @default("LEAD")

  manychatId String?
  notes      String?

  challengeParticipants ChallengeParticipant[]
  coachingClient        CoachingClient?
  summaries             AISummary[]

  @@index([status])
  @@index([createdAt])
}

model ChallengeGroup {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  name      String
  startDate DateTime
  endDate   DateTime
  status  String @default("UPCOMING")
  maxSize Int    @default(10)

  coachNotes String?

  participants ChallengeParticipant[]

  @@index([status])
  @@index([startDate])
}

model ChallengeParticipant {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  prospect   Prospect @relation(fields: [prospectId], references: [id])
  prospectId String

  group   ChallengeGroup @relation(fields: [groupId], references: [id])
  groupId String

  day1Done Boolean @default(false)
  day2Done Boolean @default(false)
  day3Done Boolean @default(false)
  day4Done Boolean @default(false)
  day5Done Boolean @default(false)
  day6Done Boolean @default(false)
  day7Done Boolean @default(false)

  engagementScore Int?
  isSerious       Boolean @default(false)
  coachNotes      String?

  @@unique([prospectId, groupId])
}

model CoachingClient {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  prospect   Prospect @relation(fields: [prospectId], references: [id])
  prospectId String   @unique

  contractStart DateTime
  contractEnd   DateTime
  priceEur      Int     @default(3000)

  objectives    String?
  progressNotes String?
  isActive      Boolean @default(true)
}

model AISummary {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  prospect   Prospect @relation(fields: [prospectId], references: [id])
  prospectId String

  type    String @default("ONBOARDING")
  content String

  @@index([prospectId])
}

// =============================================================
// APP CLIENTE D5 — tables partagées avec d5-clients-app
// =============================================================

model AppClient {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email           String    @unique
  passwordHash    String    @map("password_hash")
  firstName       String    @map("first_name")
  lastName        String    @map("last_name")
  phone           String?
  birthDate       DateTime? @map("birth_date") @db.Date
  gender          String?
  objectives      String?
  isActive        Boolean   @default(true) @map("is_active")
  isBlocked       Boolean   @default(false) @map("is_blocked")
  isRebootOnly    Boolean   @default(false) @map("is_reboot_only")
  rebootStartDate DateTime? @map("reboot_start_date") @db.Date
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  progressEntries  AppProgressEntry[]
  nutritionFiles   AppNutritionFile[]
  trainingPrograms TrainingProgram[]

  @@map("clients")
}

model AppProgressEntry {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientId       String   @map("client_id") @db.Uuid
  entryDate      DateTime @map("entry_date") @db.Date
  heightCm       Decimal? @map("height_cm") @db.Decimal(5, 1)
  ageYears       Int?     @map("age_years")
  weightKg       Decimal? @map("weight_kg") @db.Decimal(5, 2)
  bodyFatPercent Decimal? @map("body_fat_percent") @db.Decimal(4, 1)
  chestCm        Decimal? @map("chest_cm") @db.Decimal(5, 1)
  waistCm        Decimal? @map("waist_cm") @db.Decimal(5, 1)
  hipsCm         Decimal? @map("hips_cm") @db.Decimal(5, 1)
  armsCm         Decimal? @map("arms_cm") @db.Decimal(5, 1)
  thighsCm       Decimal? @map("thighs_cm") @db.Decimal(5, 1)
  notes          String?
  createdAt      DateTime @default(now()) @map("created_at")

  client AppClient @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([clientId, entryDate])
  @@index([clientId])
  @@map("progress_entries")
}

model AppNutritionFile {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientId   String   @map("client_id") @db.Uuid
  name       String
  fileUrl    String   @map("file_url")
  fileName   String   @map("file_name")
  fileSize   Int?     @map("file_size")
  uploadedAt DateTime @default(now()) @map("uploaded_at")
  isActive   Boolean  @default(true) @map("is_active")

  client AppClient @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@map("nutrition_files")
}

model ExerciseLibrary {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String
  description  String?
  muscles      String[]
  vimeoVideoId String?  @map("vimeo_video_id")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")

  sessionExercises SessionExercise[]

  @@map("exercise_library")
}

model TrainingProgram {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientId      String    @map("client_id") @db.Uuid
  name          String
  description   String?
  startDate     DateTime? @map("start_date") @db.Date
  endDate       DateTime? @map("end_date") @db.Date
  weeksDuration Int?      @map("weeks_duration")
  isActive      Boolean   @default(true) @map("is_active")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  client   AppClient        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  sessions TrainingSession[]

  @@index([clientId])
  @@map("training_programs")
}

model TrainingSession {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  programId       String   @map("program_id") @db.Uuid
  name            String
  dayOfWeek       Int?     @map("day_of_week")
  orderIndex      Int      @default(0) @map("order_index")
  durationMinutes Int?     @map("duration_minutes")
  notes           String?
  createdAt       DateTime @default(now()) @map("created_at")

  program     TrainingProgram     @relation(fields: [programId], references: [id], onDelete: Cascade)
  exercises   SessionExercise[]
  completions SessionCompletion[]

  @@index([programId])
  @@map("training_sessions")
}

model SessionExercise {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sessionId         String   @map("session_id") @db.Uuid
  libraryExerciseId String?  @map("library_exercise_id") @db.Uuid
  name              String
  sets              Int?
  reps              String?
  restSeconds       Int?     @map("rest_seconds")
  vimeoVideoId      String?  @map("vimeo_video_id")
  orderIndex        Int      @default(0) @map("order_index")
  notes             String?
  createdAt         DateTime @default(now()) @map("created_at")

  session         TrainingSession   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  libraryExercise ExerciseLibrary?  @relation(fields: [libraryExerciseId], references: [id])
  setResults      ExerciseSetResult[]

  @@index([sessionId])
  @@map("exercises")
}

// =============================================================
// REBOOT 40 — séances template et suivi client
// =============================================================

model RebootSession {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name            String
  muscleGroup     String   @map("muscle_group")
  location        String
  orderIndex      Int      @default(0) @map("order_index")
  description     String?
  durationMinutes Int?     @map("duration_minutes")
  createdAt       DateTime @default(now()) @map("created_at")

  exercises   RebootExercise[]
  completions RebootCompletion[]

  @@map("reboot_sessions")
}

model RebootExercise {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sessionId    String   @map("session_id") @db.Uuid
  name         String
  sets         Int?
  reps         String?
  restSeconds  Int?     @map("rest_seconds")
  vimeoVideoId String?  @map("vimeo_video_id")
  orderIndex   Int      @default(0) @map("order_index")
  notes        String?
  createdAt    DateTime @default(now()) @map("created_at")

  session RebootSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@map("reboot_exercises")
}

model RebootCompletion {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientId    String   @map("client_id") @db.Uuid
  sessionId   String   @map("session_id") @db.Uuid
  completedAt DateTime @default(now()) @map("completed_at")
  notes       String?

  session RebootSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([clientId, sessionId])
  @@index([clientId])
  @@map("reboot_completions")
}

// =============================================================
// SESSION COMPLETIONS — suivi des séances réalisées
// =============================================================

model SessionCompletion {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sessionId       String   @map("session_id") @db.Uuid
  clientId        String   @map("client_id") @db.Uuid
  completedAt     DateTime @default(now()) @map("completed_at")
  durationMinutes Int?     @map("duration_minutes")
  notes           String?
  initiatedBy     String   @default("client") @map("initiated_by")

  session    TrainingSession     @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  setResults ExerciseSetResult[]

  @@index([clientId])
  @@index([sessionId])
  @@map("session_completions")
}

model ExerciseSetResult {
  id           String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  completionId String  @map("completion_id") @db.Uuid
  exerciseId   String  @map("exercise_id") @db.Uuid
  setNumber    Int     @map("set_number")
  weightActual String? @map("weight_actual")
  repsActual   String? @map("reps_actual")
  completed    Boolean @default(true)

  completion SessionCompletion @relation(fields: [completionId], references: [id], onDelete: Cascade)
  exercise   SessionExercise   @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  @@index([completionId])
  @@map("exercise_set_results")
}
