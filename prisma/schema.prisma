generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Prospect {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name  String
  phone String @unique
  email String?
  age   Int?

  qualifObjectif   String?
  qualifDelai      String?
  qualifFrein      String?
  qualifExperience String?
  qualifDisponible String?
  qualifSante      String?
  qualifMotivation String?
  qualifBudget     String?

  weight        Float?
  height        Float?
  availableDays String?
  nutritionInfo String?
  photosReceived Boolean @default(false)
  onboardingDone Boolean @default(false)

  // LEAD | ONBOARDING | CHALLENGE | CALL_SCHEDULED | CLIENT | DECLINED | GHOST
  status String @default("LEAD")

  manychatId String?
  notes      String?

  challengeParticipants ChallengeParticipant[]
  coachingClient        CoachingClient?
  summaries             AISummary[]

  @@index([status])
  @@index([createdAt])
}

model ChallengeGroup {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  name      String
  startDate DateTime
  endDate   DateTime
  // UPCOMING | ACTIVE | COMPLETED
  status  String @default("UPCOMING")
  maxSize Int    @default(10)

  coachNotes String?

  participants ChallengeParticipant[]

  @@index([status])
  @@index([startDate])
}

model ChallengeParticipant {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  prospect   Prospect @relation(fields: [prospectId], references: [id])
  prospectId String

  group   ChallengeGroup @relation(fields: [groupId], references: [id])
  groupId String

  day1Done Boolean @default(false)
  day2Done Boolean @default(false)
  day3Done Boolean @default(false)
  day4Done Boolean @default(false)
  day5Done Boolean @default(false)
  day6Done Boolean @default(false)
  day7Done Boolean @default(false)

  engagementScore Int?
  isSerious       Boolean @default(false)
  coachNotes      String?

  @@unique([prospectId, groupId])
}

model CoachingClient {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  prospect   Prospect @relation(fields: [prospectId], references: [id])
  prospectId String   @unique

  contractStart DateTime
  contractEnd   DateTime
  priceEur      Int     @default(3000)

  objectives    String?
  progressNotes String?
  isActive      Boolean @default(true)
}

model AISummary {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  prospect   Prospect @relation(fields: [prospectId], references: [id])
  prospectId String

  // ONBOARDING | PRE_CALL | CHALLENGE_WEEK
  type    String @default("ONBOARDING")
  content String

  @@index([prospectId])
}

// =============================================================
// APP CLIENTE D5 — tables partagées avec d5-clients-app
// Ces modèles sont créés via db/schema.sql dans l'app cliente
// Prisma les lit/écrit via @@map sur les noms de tables réels
// =============================================================

model AppClient {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email           String    @unique
  passwordHash    String    @map("password_hash")
  firstName       String    @map("first_name")
  lastName        String    @map("last_name")
  phone           String?
  birthDate       DateTime? @map("birth_date") @db.Date
  gender          String?
  objectives      String?
  isActive        Boolean   @default(true) @map("is_active")
  isRebootOnly    Boolean   @default(false) @map("is_reboot_only")
  rebootStartDate DateTime? @map("reboot_start_date") @db.Date
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  progressEntries AppProgressEntry[]
  nutritionFiles  AppNutritionFile[]

  @@map("clients")
}

model AppProgressEntry {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientId       String   @map("client_id") @db.Uuid
  entryDate      DateTime @map("entry_date") @db.Date
  weightKg       Decimal? @map("weight_kg") @db.Decimal(5, 2)
  bodyFatPercent Decimal? @map("body_fat_percent") @db.Decimal(4, 1)
  chestCm        Decimal? @map("chest_cm") @db.Decimal(5, 1)
  waistCm        Decimal? @map("waist_cm") @db.Decimal(5, 1)
  hipsCm         Decimal? @map("hips_cm") @db.Decimal(5, 1)
  armsCm         Decimal? @map("arms_cm") @db.Decimal(5, 1)
  thighsCm       Decimal? @map("thighs_cm") @db.Decimal(5, 1)
  notes          String?
  createdAt      DateTime @default(now()) @map("created_at")

  client AppClient @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([clientId, entryDate])
  @@index([clientId])
  @@map("progress_entries")
}

model AppNutritionFile {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientId   String   @map("client_id") @db.Uuid
  name       String
  fileUrl    String   @map("file_url")
  fileName   String   @map("file_name")
  fileSize   Int?     @map("file_size")
  uploadedAt DateTime @default(now()) @map("uploaded_at")
  isActive   Boolean  @default(true) @map("is_active")

  client AppClient @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@map("nutrition_files")
}
