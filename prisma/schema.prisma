generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Prospect {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name  String
  phone String @unique
  email String?
  age   Int?

  qualifObjectif     String?
  qualifDelai        String?
  qualifFrein        String?
  qualifExperience   String?
  qualifDisponible   String?
  qualifSante        String?
  qualifMotivation   String?
  qualifBudget       String?

  weight        Float?
  height        Float?
  availableDays String?
  nutritionInfo String?
  photosReceived Boolean @default(false)
  onboardingDone Boolean @default(false)

  // LEAD | ONBOARDING | CHALLENGE | CALL_SCHEDULED | CLIENT | DECLINED | GHOST
  status String @default("LEAD")

  manychatId String?
  notes String?

  challengeParticipants ChallengeParticipant[]
  coachingClient        CoachingClient?
  summaries             AISummary[]

  @@index([status])
  @@index([createdAt])
}

model ChallengeGroup {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  name      String
  startDate DateTime
  endDate   DateTime
  // UPCOMING | ACTIVE | COMPLETED
  status    String @default("UPCOMING")
  maxSize   Int    @default(10)

  coachNotes String?

  participants ChallengeParticipant[]

  @@index([status])
  @@index([startDate])
}

model ChallengeParticipant {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  prospect   Prospect @relation(fields: [prospectId], references: [id])
  prospectId String

  group   ChallengeGroup @relation(fields: [groupId], references: [id])
  groupId String

  day1Done Boolean @default(false)
  day2Done Boolean @default(false)
  day3Done Boolean @default(false)
  day4Done Boolean @default(false)
  day5Done Boolean @default(false)
  day6Done Boolean @default(false)
  day7Done Boolean @default(false)

  engagementScore Int?
  isSerious       Boolean @default(false)
  coachNotes      String?

  @@unique([prospectId, groupId])
}

model CoachingClient {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  prospect   Prospect @relation(fields: [prospectId], references: [id])
  prospectId String   @unique

  contractStart DateTime
  contractEnd   DateTime
  priceEur      Int      @default(3000)

  objectives    String?
  progressNotes String?
  isActive      Boolean @default(true)
}

model AISummary {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  prospect   Prospect @relation(fields: [prospectId], references: [id])
  prospectId String

  // ONBOARDING | PRE_CALL | CHALLENGE_WEEK
  type    String @default("ONBOARDING")
  content String

  @@index([prospectId])
}
